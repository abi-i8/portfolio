    <!-- ═══════════════════════════════════════════════
     SCRIPTS
═══════════════════════════════════════════════ -->
    <script>
      /* ── CURSOR ── */
      (function () {
        if (window.matchMedia('(pointer:coarse)').matches) return;
        const cd = document.getElementById('cursor'), co = document.getElementById('cursor-outer');
        let mx = 0, my = 0, rx = 0, ry = 0;
        window.addEventListener('mousemove', e => { mx = e.clientX; my = e.clientY; cd.style.left = mx + 'px'; cd.style.top = my + 'px'; }, { passive: true });
        (function t() { rx += (mx - rx) * .1; ry += (my - ry) * .1; co.style.left = rx + 'px'; co.style.top = ry + 'px'; requestAnimationFrame(t); })();
        document.addEventListener('mouseover', e => { if (e.target.closest('a,button,.tag')) { co.style.width = '54px'; co.style.height = '54px'; co.style.borderColor = 'var(--cyan)'; } }, { passive: true });
        document.addEventListener('mouseout', e => { if (e.target.closest('a,button,.tag')) { co.style.width = '40px'; co.style.height = '40px'; co.style.borderColor = 'rgba(124,77,255,.5)'; } }, { passive: true });
      })();

      /* ── SCROLL PROGRESS ── */
      const prog = document.getElementById('prog');
      window.addEventListener('scroll', () => { prog.style.width = (window.scrollY / (document.body.scrollHeight - window.innerHeight) * 100) + '%'; }, { passive: true });

      /* ── NAV ── */
      const nav = document.getElementById('nav');
      window.addEventListener('scroll', () => nav.classList.toggle('solid', window.scrollY > 40), { passive: true });

      /* ── MOBILE MENU ── */
      const nham = document.getElementById('nham'), mob = document.getElementById('mob');
      function oMob() {
        mob.classList.add('open');
        nham.classList.add('open');
        document.body.classList.add('mob-open');
        mob.setAttribute('aria-hidden', 'false');
        nham.setAttribute('aria-expanded', 'true');
        document.body.style.overflow = 'hidden';
      }
      function cMob() {
        mob.classList.remove('open');
        nham.classList.remove('open');
        document.body.classList.remove('mob-open');
        mob.setAttribute('aria-hidden', 'true');
        nham.setAttribute('aria-expanded', 'false');
        document.body.style.overflow = '';
      }
      nham.addEventListener('click', () => {
        if (mob.classList.contains('open')) cMob();
        else oMob();
      });
      window.addEventListener('keydown', e => { if (e.key === 'Escape') cMob(); });

      /* ── MAGNETIC BUTTONS ── */
      document.querySelectorAll('.btn').forEach(b => {
        b.addEventListener('mousemove', e => {
          const r = b.getBoundingClientRect();
          const dx = e.clientX - r.left - r.width / 2, dy = e.clientY - r.top - r.height / 2;
          b.style.transform = `translate(${dx * .22}px,${dy * .22}px) translateY(-2px)`;
          b.style.setProperty('--mx', ((e.clientX - r.left) / r.width * 100) + '%');
          b.style.setProperty('--my', ((e.clientY - r.top) / r.height * 100) + '%');
        });
        b.addEventListener('mouseleave', () => { b.style.transform = ''; });
      });

      /* ── SCROLL REVEAL ── */
      const revs = document.querySelectorAll('.reveal');
      if ('IntersectionObserver' in window) {
        const obs = new IntersectionObserver(es => { es.forEach(e => { if (e.isIntersecting) { e.target.classList.add('in'); obs.unobserve(e.target); } }); }, { threshold: .08, rootMargin: '0px 0px -28px 0px' });
        revs.forEach(el => obs.observe(el));
      } else revs.forEach(el => el.classList.add('in'));

      /* ── CARD 3D TILT ── */
      document.querySelectorAll('.scard,.skc,.pc,.ei,.ai').forEach(c => {
        c.addEventListener('mousemove', e => {
          const r = c.getBoundingClientRect();
          const dx = (e.clientX - r.left - r.width / 2) / (r.width / 2);
          const dy = (e.clientY - r.top - r.height / 2) / (r.height / 2);
          c.style.transform = `perspective(900px) rotateX(${-dy * 5}deg) rotateY(${dx * 5}deg) translateY(-4px)`;
        });
        c.addEventListener('mouseleave', () => { c.style.transform = ''; });
      });

      /* ── SMOOTH ANCHORS ── */
      document.querySelectorAll('a[href^="#"]').forEach(a => {
        a.addEventListener('click', e => {
          const t = document.querySelector(a.getAttribute('href'));
          if (t) { e.preventDefault(); t.scrollIntoView({ behavior: 'smooth', block: 'start' }); }
        });
      });

      /* ═══════════════════════════════════════════════
         EVE ROBOT - SCROLL PHYSICS + CHATBOT
      ═══════════════════════════════════════════════ */
      (function () {
        const eve = document.getElementById('eve');
        const cchat = document.getElementById('cchat');
        const cclose = document.getElementById('cclose');
        const cmsgs = document.getElementById('cmsgs');
        const cin = document.getElementById('cin');
        const csend = document.getElementById('csend');
        let userName = '';

        /* ── Scroll physics ── */
        let lastY = window.scrollY, scrollDir = 0, scrollTimer = null, idleOpenTimer = null;
        window.robotState = 'closed';
        let chatOpen = false, chatHasOpened = false, hasEverClosed = false;

        /* EVE Wake-Up Sequence: closed → idle → chat */
        eve.className = 'eve-robot-wrap closed';
        setTimeout(() => {
          if (window.robotState !== 'closed') return; // Don't wake up if already interacted
          setRobotState('idle');
          idleOpenTimer = setTimeout(openChat, 1500);
        }, 2200);

        function setRobotState(s) {
          if (window.robotState === s) return;
          window.robotState = s;
          eve.className = 'eve-robot-wrap ' + s;

          if (s !== 'idle') {
            clearTimeout(idleOpenTimer);
            if (chatOpen) closeChat(false);
          }
        }

        window.addEventListener('scroll', () => {
          const y = window.scrollY;
          if (Math.abs(y - lastY) < 12) return; // Ignore micro-scrolls
          scrollDir = y > lastY ? 1 : -1;
          lastY = y;

          if (window.robotState === 'closed') {
            setRobotState('idle');
          }

          setRobotState(scrollDir === 1 ? 'falling' : 'flying');
          clearTimeout(scrollTimer);
          scrollTimer = setTimeout(() => {
            if (window.robotState !== 'idle') setRobotState('idle');
          }, 900);
        }, { passive: true });

        function openChat() {
          clearTimeout(idleOpenTimer);
          chatOpen = true;
          cchat.classList.add('open');
          eve.setAttribute('aria-expanded', 'true');

          if (!chatHasOpened) {
            chatHasOpened = true;
            setTimeout(() => addBotMsg("Greetings. I am EVE, Abi's professional AI ChatBot. I am ready to provide detailed insights into his work, education, and creative expertise. How may I assist you today?"), 350);
          }
          setTimeout(() => cin.focus(), 420);
        }
        function closeChat(isManual = false) {
          clearTimeout(idleOpenTimer);
          chatOpen = false;
          cchat.classList.remove('open');
          eve.setAttribute('aria-expanded', 'false');
          if (isManual) {
            hasEverClosed = true;
          }
        }

        eve.addEventListener('click', () => {
          if (chatOpen) closeChat(true);
          else openChat();
        });
        eve.addEventListener('keydown', e => { if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); eve.click(); } });
        cclose.addEventListener('click', e => { e.stopPropagation(); closeChat(true); });
        window.addEventListener('keydown', e => { if (e.key === 'Escape' && chatOpen) { closeChat(true); } });

        function addMsg(txt, who) {
          const d = document.createElement('div');
          d.className = 'cmsg ' + who;
          d.textContent = txt;
          cmsgs.appendChild(d);
          cmsgs.scrollTop = cmsgs.scrollHeight;
        }
        function addBotMsg(txt) {
          if (!txt) return;
          const typing = document.createElement('div');
          typing.className = 'cmsg bot';
          typing.innerHTML = '<span class="typing-dots"><span></span><span></span><span></span></span>';
          cmsgs.appendChild(typing);
          cmsgs.scrollTop = cmsgs.scrollHeight;
          setTimeout(() => { typing.remove(); addMsg(txt, 'bot'); }, 900);
        }



        /* ── Agentic RAG-Style Knowledge Base ── */
        const RESUME_INFO = {
          name: "Abi",
          age: 25, // Born Aug 19, 2001
          profile: "Abi is a Creative Media Technologist from Kerala, specializing in the intersection of branding, AI workflows, and immersive web technologies.",
          education: [
            "MBA in Travel & Tourism Management, Central University of Kerala (2023-2025) - CGPA 6.67",
            "BA English Literature, Kannur University (2020-2023) - CGPA 6.83",
            "Certifications: Web Based Technologies & Multimedia Applications, Online Learning & Multimedia Applications"
          ],
          skills: {
            ai: ["Prompt Engineering", "AI Image & Video Generation", "Workflow Automation", "Claude", "ChatGPT"],
            web: ["Three.js", "WebGL", "GLSL Shaders", "React", "Next.js", "JavaScript"],
            creative: ["Adobe Photoshop", "Adobe Premiere Pro", "Adobe After Effects", "Figma", "Blender"]
          },
          achievements: [
            "Photography & Visual Narrative Distinction (awarded twice) for conceptual and artistic composition.",
            "Recognized for high-impact Cinematic Production and strategic digital brand communication."
          ],
          experience: "Currently contributing as a Creative professional at WebCastle Media. Abi has been operating independently as a freelance media specialist since 2020.",
          contact: {
            phone: "+91 81118 00628",
            insta: "@abi.jith_i8",
            linkedin: "abijithar"
          }
        };

        const KB = [
          { k: ['hello', 'hi', 'hey', 'sup', 'greetings'], r: ["Greetings! I am EVE, Abi's AI assistant. How may I assist you with his professional profile today?", "Welcome. I am EVE. I can provide detailed insights into Abi's expertise in Creative Media and AI. What would you like to know?"] },
          { k: ['who', 'abi', 'about', 'tell me about him', 'what do you do'], r: [`${RESUME_INFO.profile} He is ${RESUME_INFO.age} years old and brings a unique blend of literary foundation and technical innovation to every project.`] },
          { k: ['age', 'old', 'born', 'birthday', 'year'], r: [`Abi is ${RESUME_INFO.age} years old (born in 2001).`] },
          { k: ['education', 'study', 'degree', 'university', 'mba', 'ba'], r: [`Abi holds the following qualifications: \n- ${RESUME_INFO.education.join('\n- ')}`] },
          { k: ['skill', 'can', 'know', 'expert', 'tech', 'stack'], r: [`Abi's technical stack includes:\n- AI: ${RESUME_INFO.skills.ai.join(', ')}\n- Web & 3D: ${RESUME_INFO.skills.web.join(', ')}\n- Creative: ${RESUME_INFO.skills.creative.join(', ')}`] },
          { k: ['experience', 'work', 'job', 'career', 'webcastle', 'freelance'], r: [RESUME_INFO.experience] },
          { k: ['award', 'achievement', 'win', 'competition', 'distinction'], r: [`Abi has received several honors:\n- ${RESUME_INFO.achievements.join('\n- ')}`] },
          { k: ['contact', 'hire', 'reach', 'call', 'number'], r: [`You can reach Abi via:\n- Phone: ${RESUME_INFO.contact.phone}\n- LinkedIn: ${RESUME_INFO.contact.linkedin}\n- Instagram: ${RESUME_INFO.contact.insta}`] },
          { k: ['three', 'webgl', '3d', 'canvas', 'shader'], r: ["Yes, Abi is an expert in Three.js and WebGL. This entire portfolio, including my own 3D architecture, is built using these technologies."] },
          { k: ['ai', 'artificial', 'intelligence', 'gpt', 'claude', 'prompt'], r: [`Abi leverages advanced AI workflows, including: ${RESUME_INFO.skills.ai.join(', ')}. He integrates AI to enhance cinematic production and creative efficiency.`] },
          { k: ['video', 'photo', 'camera', 'edit', 'cinema', 'motion'], r: ["Photography and Cinematic production are core to Abi's identity. He holds distinctions in Visual Narrative and is proficient in Premiere Pro and After Effects."] },
          { k: ['language', 'speak'], r: ["Abi is fluent in English, Malayalam, Hindi, and Tamil."] }
        ];

        let chatHistory = [];


        function getBotReply(msg) {
          const m = msg.toLowerCase();
          chatHistory.push({ role: 'user', content: m });
          if (chatHistory.length > 10) chatHistory.shift();

          // Personalized Name Recognition
          if (m.includes("my name is ") || m.includes("i am ")) {
            let name = m.split("is ").pop() || m.split("am ").pop();
            if (name && name.length < 20) {
              userName = name.charAt(0).toUpperCase() + name.slice(1);
              return `It is a pleasure to meet you, ${userName}. I have updated my records. How can I assist you with Abijith's portfolio?`;
            }
          }

          // Social & Continuity Logic
          if (m.includes("thank") || m.includes("thanks")) return "You are most welcome. Is there anything else about Abijith's expertise you'd like to explore?";
          if (m.includes("how are you")) return "My systems are operating at peak efficiency, thank you for asking. How can I help you today?";
          if (m.includes("bye") || m.includes("goodbye")) return "Farewell. I will be here if you require further assistance with Abijith's professional logs.";

          // Enhanced Agentic Retrieval Logic
          let matched = KB.find(entry => entry.k.some(k => m.includes(k)));
          if (matched) {
            let res = matched.r[Math.floor(Math.random() * matched.r.length)];
            chatHistory.push({ role: 'bot', content: res });
            return res;
          }

          // RAG Fallback - Semantic check for Resume Data
          if (m.includes("resume") || m.includes("cv") || m.includes("detail") || m.includes("more")) {
            return `I can provide detailed information on Abijith's ${RESUME_INFO.skills.ai[0]} expertise, his ${RESUME_INFO.education[0]}, or his current role at WebCastle Media. Which would you like to explore?`;
          }

          const fb = [
            "I apologize, but I don't have that specific data in my logs. I can, however, detail Abijith's achievements in Cinematic Production or his proficiency in Three.js.",
            "That query is outside my current knowledge base. Would you like to know about his MBA from Central University of Kerala or his freelance creative work?",
            "I am programmed for professional inquiries. Perhaps you'd like to know about Abijith's skills in Figma, Blender, or AI-assisted content generation?"
          ];
          let finalFb = fb[Math.floor(Math.random() * fb.length)];
          chatHistory.push({ role: 'bot', content: finalFb });
          return finalFb;
        }

        function sendMsg() {
          const txt = cin.value.trim();
          if (!txt) return;
          addMsg(txt, 'usr');
          cin.value = '';
          addBotMsg(getBotReply(txt));
        }

        csend.addEventListener('click', sendMsg);
        cin.addEventListener('keydown', e => { if (e.key === 'Enter') sendMsg(); });
      })();

      /* ═══════════════════════════════════════════════
         THREE.JS SPACE HERO
      ═══════════════════════════════════════════════ */
      (function () {
        if (typeof THREE === 'undefined') return;
        const cv = document.getElementById('hc');
        if (!cv) return;
        const PM = window.matchMedia('(prefers-reduced-motion:reduce)').matches;
        let W = window.innerWidth, H = window.innerHeight;

        const scene = new THREE.Scene();
        const cam = new THREE.PerspectiveCamera(50, W / H, .1, 150);
        cam.position.set(0, .2, 7.8);

        const rend = new THREE.WebGLRenderer({ canvas: cv, antialias: true, alpha: false, powerPreference: 'high-performance' });
        rend.setPixelRatio(Math.min(devicePixelRatio, 2));
        rend.setSize(W, H);
        rend.setClearColor(0x01010A, 1);

        /* ── TEXTURE LOADER ── */
        const txl = new THREE.TextureLoader();

        /* ── SUNLIGHT ── */
        const sunDir = new THREE.Vector3(-2, .5, 1.5).normalize();
        const sunLight = new THREE.DirectionalLight(0xffffff, 1.8);
        sunLight.position.copy(sunDir.clone().multiplyScalar(10));
        scene.add(sunLight);
        scene.add(new THREE.AmbientLight(0x111122, 0.25));

        /* ── EARTH - NASA Blue Marble + city lights texture ── */
        const earthDayTex = txl.load('https://unpkg.com/three-globe/example/img/earth-blue-marble.jpg');
        const earthNightTex = txl.load('https://unpkg.com/three-globe/example/img/earth-night.jpg');
        const eVS = `
    varying vec2 vUv;varying vec3 vN;varying vec3 vNW;varying vec3 vVD;
    void main(){
      vUv=uv;
      vN=normalize(normalMatrix*normal);
      vNW=normalize(mat3(modelMatrix)*normal);
      vec4 mv=modelViewMatrix*vec4(position,1.);
      vVD=normalize(-mv.xyz);
      gl_Position=projectionMatrix*mv;
    }`;
        const eFS = `
    uniform sampler2D uDay;
    uniform sampler2D uNight;
    uniform vec3 uSun;
    varying vec2 vUv;varying vec3 vN;varying vec3 vNW;varying vec3 vVD;
    void main(){
      vec3 dayCol=texture2D(uDay,vUv).rgb;
      vec3 nightCol=texture2D(uNight,vUv).rgb;
      float sun=dot(vNW,normalize(uSun));
      /* smooth day/night terminator */
      float dayMix=smoothstep(-0.12,0.28,sun);
      vec3 col=mix(nightCol*1.6,dayCol,dayMix);
      /* ocean specular highlight on day side */
      float spec=pow(max(0.,dot(reflect(-normalize(uSun),vNW),vVD)),48.)*dayMix;
      col+=vec3(.6,.7,.8)*spec*.35;
      /* fresnel atmosphere rim glow */
      float fr=pow(1.-clamp(dot(vVD,vN),0.,1.),2.8);
      vec3 atm=vec3(.12,.42,.95);
      col+=atm*fr*.65;
      col+=vec3(.85,.92,1.)*fr*fr*.3;
      gl_FragColor=vec4(col,1.);
    }`;
        const planetMat = new THREE.ShaderMaterial({
          vertexShader: eVS, fragmentShader: eFS,
          uniforms: { uDay: { value: earthDayTex }, uNight: { value: earthNightTex }, uSun: { value: sunDir } }
        });
        const planetGroup = new THREE.Group();
        scene.add(planetGroup);

        const planet = new THREE.Mesh(new THREE.SphereGeometry(1.8, 128, 128), planetMat);
        planetGroup.add(planet);

        /* Responsive Planet Positioning */
        function updatePlanetPos() {
          const isMob = window.innerWidth < 768;
          planetGroup.position.set(isMob ? 0 : 3.4, isMob ? -2.0 : -0.2, 0);
          if (isMob) {
            cam.fov = 60; // Wider field for mobile
            cam.updateProjectionMatrix();
          } else {
            cam.fov = 50;
            cam.updateProjectionMatrix();
          }
        }
        updatePlanetPos();

        /* ── CLOUD LAYER - separate sphere, independent rotation ── */
        const cloudTex = txl.load('https://raw.githubusercontent.com/mrdoob/three.js/master/examples/textures/planets/earth_clouds_1024.png');
        const cloudsMat = new THREE.MeshPhongMaterial({
          map: cloudTex, transparent: true, opacity: 0.32, depthWrite: false, side: THREE.DoubleSide
        });
        const clouds = new THREE.Mesh(new THREE.SphereGeometry(1.83, 64, 64), cloudsMat);
        planetGroup.add(clouds);

        /* ── ATMOSPHERE - smoothed fresnel glow ── */
        const aVS = `
    varying vec3 vN;
    varying vec3 vVD;
    void main(){
      vN = normalize(normalMatrix * normal);
      vec4 mv = modelViewMatrix * vec4(position, 1.0);
      vVD = normalize(-mv.xyz);
      gl_Position = projectionMatrix * mv;
    }`;
        const aFS1 = `
    varying vec3 vN;
    varying vec3 vVD;
    void main(){
      float intensity = pow(1.0 - max(dot(vN, vVD), 0.0), 10.0);
      vec3 glowCol = mix(vec3(0.01, 0.05, 0.2), vec3(0.05, 0.3, 0.9), intensity);
      gl_FragColor = vec4(glowCol, intensity * 0.4);
    }`;
        const aFS2 = `
    varying vec3 vN;
    varying vec3 vVD;
    void main(){
      float intensity = pow(1.0 - max(dot(vN, vVD), 0.0), 30.0);
      gl_FragColor = vec4(vec3(0.05, 0.25, 0.8), intensity * 0.15);
    }`;
        function mkAtm(radius, fs) {
          const m = new THREE.ShaderMaterial({ vertexShader: aVS, fragmentShader: fs, transparent: true, side: THREE.BackSide, depthWrite: false, blending: THREE.AdditiveBlending });
          const mesh = new THREE.Mesh(new THREE.SphereGeometry(radius, 128, 128), m);
          planetGroup.add(mesh); return mesh;
        }
        const atm1 = mkAtm(1.82, aFS1);
        const atm2 = mkAtm(1.98, aFS2);

        /* orbit rings */
        function mkRing(r, op, rx, ry, col) {
          const pts = []; for (let i = 0; i <= 192; i++) { const a = i / 192 * Math.PI * 2; pts.push(new THREE.Vector3(Math.cos(a) * r, Math.sin(a) * r, 0)); }
          const l = new THREE.LineLoop(new THREE.BufferGeometry().setFromPoints(pts), new THREE.LineBasicMaterial({ color: col, transparent: true, opacity: op }));
          l.rotation.x = rx; l.rotation.y = ry; l.position.copy(planet.position); return l;
        }
        const rings = [mkRing(2.5, .25, .5, .15, 0x00D4FF), mkRing(3.2, .12, -.65, .3, 0x7C4DFF), mkRing(3.9, .06, .85, -.25, 0xFFB84D)];
        rings.forEach(r => planetGroup.add(r));

        /* ── EARTH'S MOON - Texture Mapped + Group Pivot for depth occlusion ── */
        const moonTex = txl.load('https://raw.githubusercontent.com/mrdoob/three.js/master/examples/textures/planets/moon_1024.jpg');
        const moonMat = new THREE.MeshStandardMaterial({ map: moonTex, roughness: 0.9, metalness: 0.1 });
        const moonGroup = new THREE.Group();
        planetGroup.add(moonGroup);
        const moon = new THREE.Mesh(new THREE.SphereGeometry(.32, 48, 48), moonMat);
        moon.position.set(3.2, 0, 0);
        moonGroup.add(moon);
        moonGroup.rotation.x = 0.089;

        /* ── GALAXY - logarithmic spiral arms ── */
        const PC = 5000, ARMS = 3;
        const pp = new Float32Array(PC * 3), pc = new Float32Array(PC * 3);
        for (let i = 0; i < PC; i++) {
          const i3 = i * 3, arm = (i % ARMS) / ARMS * Math.PI * 2;
          const t = Math.pow(Math.random(), .4), radius = t * 11 + .3;
          const angle = Math.log(Math.max(radius, .1)) * 2.2 + arm + (Math.random() - .5) * (.5 + radius * .05);
          const dh = (Math.random() - .5) * Math.exp(-radius * .1) * .55;
          pp[i3] = Math.cos(angle) * radius; pp[i3 + 1] = dh; pp[i3 + 2] = Math.sin(angle) * radius;
          const tr = Math.min(radius / 11, 1);
          pc[i3] = .35 + tr * .25; pc[i3 + 1] = .65 - tr * .15; pc[i3 + 2] = 1. - tr * .1;
        }
        const pGeo = new THREE.BufferGeometry();
        pGeo.setAttribute('position', new THREE.BufferAttribute(pp, 3));
        pGeo.setAttribute('color', new THREE.BufferAttribute(pc, 3));
        /* ── LOADING FADE ── */
        THREE.DefaultLoadingManager.onLoad = () => {
          const canv = document.getElementById('hc');
          if (canv) canv.style.opacity = '1';
        };

        const galaxy = new THREE.Points(pGeo, new THREE.PointsMaterial({ size: .022, vertexColors: true, transparent: true, opacity: .85, sizeAttenuation: true }));
        galaxy.position.set(0.5, -.4, -2.5); scene.add(galaxy);



        /* ── STARS - spherical distribution, 3 depth layers ── */
        function mkStars(count, spread, sz, op) {
          const sp = new Float32Array(count * 3);
          for (let i = 0; i < count; i++) {
            const theta = Math.random() * Math.PI * 2, phi = Math.acos(2 * Math.random() - 1), r = spread * .5 + Math.random() * spread * .5;
            sp[i * 3] = Math.sin(phi) * Math.cos(theta) * r; sp[i * 3 + 1] = Math.sin(phi) * Math.sin(theta) * r; sp[i * 3 + 2] = -Math.abs(Math.cos(phi) * r) - 2.0;
          }
          const g = new THREE.BufferGeometry(); g.setAttribute('position', new THREE.BufferAttribute(sp, 3));
          return new THREE.Points(g, new THREE.PointsMaterial({ color: 0xD4E8FF, size: sz, transparent: true, opacity: op, sizeAttenuation: true }));
        }
        scene.add(mkStars(1400, 24, .016, .65));
        scene.add(mkStars(500, 18, .03, .42));
        scene.add(mkStars(150, 13, .048, .3));

        /* shooting star */
        let shotTimer = 0;
        const shotGeo = new THREE.BufferGeometry().setFromPoints([new THREE.Vector3(0, 0, 0), new THREE.Vector3(2.5, .5, 0)]);
        const shotMat = new THREE.LineBasicMaterial({ color: 0xFFFFFF, transparent: true, opacity: 0 });
        const shot = new THREE.Line(shotGeo, shotMat); scene.add(shot);

        /* ── Mouse, Drag & Scroll ── */
        let mx = 0, my = 0, cx = 0, cy = 0, sy = 0, tsy = 0;
        let isDragging = false, px = 0, py = 0, dragRotX = 0, dragRotY = 2.3;
        window.addEventListener('mousedown', e => { isDragging = true; px = e.clientX; py = e.clientY; document.body.style.cursor = 'grabbing'; });
        window.addEventListener('mouseup', () => { isDragging = false; document.body.style.cursor = 'default'; });
        if (!PM) window.addEventListener('mousemove', e => {
          mx = (e.clientX / W - .5) * 2.5; my = (e.clientY / H - .5) * 1.6;
          if (isDragging) {
            dragRotY += (e.clientX - px) * 0.006;
            dragRotX += (e.clientY - py) * 0.006;
            dragRotX = Math.max(-1.2, Math.min(1.2, dragRotX)); /* limit vertical rotation */
            px = e.clientX; py = e.clientY;
          }
        }, { passive: true });
        window.addEventListener('scroll', () => { sy = window.scrollY; }, { passive: true });

        let t = 0, rY = 0, rRot = 0;
        const cBody = document.getElementById('eve-body');
        function tick() {
          requestAnimationFrame(tick);
          if (!PM) t += .006;
          /* responsive mouse - faster lerp */
          cx += (mx - cx) * .09; cy += (my - cy) * .09;
          /* planet rotation: mouse drag + slow auto-rotation */
          planet.rotation.x = dragRotX;
          planet.rotation.y = dragRotY + t * .05;
          planet.rotation.z = 0;
          /* clouds drift slightly faster than surface */
          clouds.rotation.x = planet.rotation.x;
          clouds.rotation.y = planet.rotation.y + t * .08;
          clouds.rotation.z = planet.rotation.z;
          [atm1, atm2].forEach(a => a.rotation.copy(planet.rotation));
          /* rings: independent counter-rotation */
          rings[0].rotation.z = t * .10; rings[1].rotation.z = -t * .06; rings[2].rotation.z = t * .036;
          rings.forEach(r => { r.rotation.x += .00025; });
          /* moon: pivot group rotates - depth-test handles occlusion automatically */
          moonGroup.rotation.y += .008;
          /* galaxy: slow rotation + subtle mouse parallax */
          galaxy.rotation.y = t * .05 + cx * .025; galaxy.rotation.x = t * .016 + cy * .012;
          /* shooting star */
          shotTimer += .016;
          if (shotTimer > 5.5) {
            const ox = -9 + Math.random() * 18, oy = 2.5 + Math.random() * 4;
            shot.position.set(ox, oy, -1); shotMat.opacity = .95;
            setTimeout(() => { shotMat.opacity = 0; shotTimer = 0; }, 480);
          }
          /* robot smooth physics */
          if (cBody && window.robotState) {
            let ty = 0, tr = 0;
            if (window.robotState === 'falling') {
              ty = 25 + Math.sin(t * 3) * 15; tr = Math.sin(t * 3) * -6;
            } else if (window.robotState === 'flying') {
              ty = -25 + Math.sin(t * 3) * 10; tr = Math.sin(t * 3) * 6;
            } else if (window.robotState === 'giggling') {
              ty = Math.sin(t * 15) * 4; tr = Math.sin(t * 15) * 3;
            } else {
              ty = Math.sin(t * 2) * -8; tr = Math.sin(t * 2) * 2;
            }
            rY += (ty - rY) * 0.08; rRot += (tr - rRot) * 0.08;
            cBody.style.transform = `translateX(-50%) translateY(${rY}px) rotate(${rRot}deg)`;
          }
          /* camera: smooth scroll parallax + mouse lean */
          tsy += (sy - tsy) * .055;
          const heroH = document.getElementById('hero').offsetHeight || H;
          const pr = Math.min(tsy / heroH, 1);
          cam.position.x = cx * .3;
          cam.position.y = .2 - pr * 2.4 + cy * .16;
          cam.position.z = 7.8 + pr * 1.6;
          cam.lookAt(0, 0, 0);
          rend.render(scene, cam);
        }
        /* Interactive Giggle */
        const robotWrap = document.getElementById('eve-robot-wrap');
        if (robotWrap) {
          robotWrap.addEventListener('click', () => {
            if (window.robotState === 'idle') {
              window.robotState = 'giggling';
              robotWrap.classList.add('giggling');
              setTimeout(() => {
                window.robotState = 'idle';
                robotWrap.classList.remove('giggling');
              }, 2500);
            }
          });
        }

        tick();

        let lastW = window.innerWidth;
        window.addEventListener('resize', () => {
          if (window.innerWidth === lastW && window.innerWidth < 768) return;
          W = window.innerWidth; H = window.innerHeight; lastW = W;
          cam.aspect = W / H;
          updatePlanetPos();
          cam.updateProjectionMatrix(); rend.setSize(W, H);
        }, { passive: true });
      })();
    </script>
</body>

</html>